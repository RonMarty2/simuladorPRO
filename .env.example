# Supabase — completar con tus credenciales de proyecto
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Sentry (OPCIONAL) — monitoreo de errores en producción.
